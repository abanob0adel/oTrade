{
  "info": {
    "name": "BunnyCDN Direct Upload API",
    "description": "API endpoints for direct frontend upload to BunnyCDN",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Generate Upload URL",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fileName\": \"my-book.pdf\",\n  \"fileType\": \"pdf\",\n  \"category\": \"books\",\n  \"fileSize\": 5242880\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/upload/generate-url",
          "host": ["{{base_url}}"],
          "path": ["api", "upload", "generate-url"]
        },
        "description": "Generate signed upload URL for direct frontend upload to BunnyCDN"
      },
      "response": []
    },
    {
      "name": "Generate Upload URL - Cover Image",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fileName\": \"book-cover.jpg\",\n  \"fileType\": \"image\",\n  \"category\": \"books\",\n  \"fileSize\": 1048576\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/upload/generate-url",
          "host": ["{{base_url}}"],
          "path": ["api", "upload", "generate-url"]
        },
        "description": "Generate upload URL for book cover image"
      },
      "response": []
    },
    {
      "name": "Generate Upload URL - Video",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fileName\": \"course-video.mp4\",\n  \"fileType\": \"video\",\n  \"category\": \"courses\",\n  \"fileSize\": 52428800\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/upload/generate-url",
          "host": ["{{base_url}}"],
          "path": ["api", "upload", "generate-url"]
        },
        "description": "Generate upload URL for video file"
      },
      "response": []
    },
    {
      "name": "Create Book with Direct Upload URLs",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": {\n    \"en\": \"Trading Psychology\",\n    \"ar\": \"علم نفس التداول\"\n  },\n  \"description\": {\n    \"en\": \"Master your trading psychology\",\n    \"ar\": \"أتقن علم نفس التداول\"\n  },\n  \"content\": {\n    \"en\": \"Full book content here\",\n    \"ar\": \"محتوى الكتاب الكامل هنا\"\n  },\n  \"coverImageUrl\": \"https://otrade.b-cdn.net/books/covers/book-cover-1234567890.jpg\",\n  \"pdfUrl\": \"https://otrade.b-cdn.net/books/files/my-book-1234567890.pdf\",\n  \"isActive\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/books",
          "host": ["{{base_url}}"],
          "path": ["api", "books"]
        },
        "description": "Create book using URLs from direct upload (no file upload to backend)"
      },
      "response": []
    },
    {
      "name": "Upload File to BunnyCDN (Direct)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "AccessKey",
            "value": "{{bunny_api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/pdf",
            "type": "text"
          }
        ],
        "body": {
          "mode": "file",
          "file": {
            "src": ""
          }
        },
        "url": {
          "raw": "https://storage.bunnycdn.com/{{storage_zone}}/books/files/test-file-{{$timestamp}}.pdf",
          "protocol": "https",
          "host": ["storage", "bunnycdn", "com"],
          "path": ["{{storage_zone}}", "books", "files", "test-file-{{$timestamp}}.pdf"]
        },
        "description": "Direct upload to BunnyCDN Storage (simulates frontend upload)"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "your_jwt_token_here",
      "type": "string"
    },
    {
      "key": "bunny_api_key",
      "value": "your_bunny_api_key",
      "type": "string"
    },
    {
      "key": "storage_zone",
      "value": "otrade",
      "type": "string"
    }
  ]
}
