    {
      "name": "Delete File by URL",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"https://otrade.b-cdn.net/books/pdfs/mybook-1234567890.pdf\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/upload/delete",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "upload", "delete"]
        },
        "description": "Delete file from BunnyCDN using CDN URL"
      },
      "response": []
    },
