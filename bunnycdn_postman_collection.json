{
  "info": {
    "name": "BunnyCDN Upload API",
    "description": "Complete BunnyCDN file upload and management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Upload Book (PDF + Cover)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "description": "PDF file"
            },
            {
              "key": "coverImage",
              "type": "file",
              "description": "Cover image (JPG, PNG)"
            }
          ]
        },
        "url": {
          "raw": "http://localhost:3000/api/upload/book",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "upload", "book"]
        },
        "description": "Upload book PDF with optional cover image"
      },
      "response": []
    },
    {
      "name": "Upload Single Image",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "image",
              "type": "file",
              "description": "Image file"
            },
            {
              "key": "folder",
              "value": "images",
              "type": "text",
              "description": "Optional folder path"
            }
          ]
        },
        "url": {
          "raw": "http://localhost:3000/api/upload/image",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "upload", "image"]
        },
        "description": "Upload single image to BunnyCDN"
      },
      "response": []
    },
