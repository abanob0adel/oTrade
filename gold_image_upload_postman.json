  "item": [
    {
      "name": "1. Create/Update Gold Info (with Image)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "coverImage",
              "type": "file",
              "src": [],
              "description": "Upload image file (JPG, PNG, WebP, GIF - Max 5MB)"
            },
            {
              "key": "title_en",
              "value": "Gold Trading - Live Prices",
              "type": "text"
            },
            {
              "key": "title_ar",
              "value": "تداول الذهب - الأسعار المباشرة",
              "type": "text"
            },
            {
              "key": "description_en",
              "value": "Gold is one of the most traded precious metals in the world. It is widely used as a safe haven asset and its price changes based on global markets and demand.",
              "type": "text"
            },
            {
              "key": "description_ar",
              "value": "الذهب هو أحد أكثر المعادن الثمينة تداولاً في العالم. يستخدم على نطاق واسع كأصل آمن ويتغير سعره بناءً على الأسواق العالمية والطلب.",
              "type": "text"
            },
            {
              "key": "faqs_en",
              "value": "[{\"question\":\"What is gold trading?\",\"answer\":\"Gold trading involves buying and selling gold to profit from price movements.\"},{\"question\":\"Why invest in gold?\",\"answer\":\"Gold is considered a safe haven asset that protects against inflation and economic uncertainty.\"}]",
              "type": "text"
            },
            {
              "key": "faqs_ar",
              "value": "[{\"question\":\"ما هو تداول الذهب؟\",\"answer\":\"تداول الذهب يتضمن شراء وبيع الذهب للاستفادة من تحركات الأسعار.\"},{\"question\":\"لماذا الاستثمار في الذهب؟\",\"answer\":\"يعتبر الذهب أصلاً آمناً يحمي من التضخم وعدم اليقين الاقتصادي.\"}]",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/gold/info",
          "host": ["{{base_url}}"],
          "path": ["gold", "info"]
        },
        "description": "Create or update gold info with image upload. Supports bilingual content (Arabic & English)."
      },
      "response": []
    },
