{
  "info": {
    "name": "Books & Articles Permissions",
    "description": "Test RBAC permissions for Books and Articles modules",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Permissions",
      "item": [
        {
          "name": "Get All Permissions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/permissions/all",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "permissions", "all"]
            },
            "description": "Get all available permissions in the system. Should include books and articles."
          },
          "response": []
        },
        {
          "name": "Get My Permissions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me/permissions",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me", "permissions"]
            },
            "description": "Get current admin's permissions. Check if books and articles are included."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Books - Admin Routes",
      "item": [
        {
          "name": "Get All Books (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/books/admin",
              "host": ["{{base_url}}"],
              "path": ["api", "books", "admin"]
            },
            "description": "Requires: books:view permission"
          },
          "response": []
        },
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title_ar\": \"كتاب تجريبي\",\n  \"title_en\": \"Test Book\",\n  \"description_ar\": \"وصف الكتاب\",\n  \"description_en\": \"Book description\",\n  \"author_ar\": \"المؤلف\",\n  \"author_en\": \"Author\",\n  \"pdfUrl\": \"https://cdn.example.com/books/test.pdf\",\n  \"coverUrl\": \"https://cdn.example.com/covers/test.jpg\",\n  \"category\": \"trading\",\n  \"isPremium\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/books",
              "host": ["{{base_url}}"],
              "path": ["api", "books"]
            },
            "description": "Requires: books:create permission"
          },
          "response": []
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title_ar\": \"كتاب محدث\",\n  \"title_en\": \"Updated Book\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/books/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "books", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "book_id_here"
                }
              ]
            },
            "description": "Requires: books:update permission"
          },
          "response": []
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/books/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "books", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "book_id_here"
                }
              ]
            },
            "description": "Requires: books:delete permission"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Articles - Admin Routes",
      "item": [
        {
          "name": "Get All Articles (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/articles/admin",
              "host": ["{{base_url}}"],
              "path": ["api", "articles", "admin"]
            },
            "description": "Requires: articles:view permission"
          },
          "response": []
        },
        {
          "name": "Create Article",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title_ar\": \"مقال تجريبي\",\n  \"title_en\": \"Test Article\",\n  \"content_ar\": \"محتوى المقال\",\n  \"content_en\": \"Article content\",\n  \"author_ar\": \"الكاتب\",\n  \"author_en\": \"Writer\",\n  \"coverUrl\": \"https://cdn.example.com/articles/test.jpg\",\n  \"category\": \"analysis\",\n  \"isPremium\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/articles",
              "host": ["{{base_url}}"],
              "path": ["api", "articles"]
            },
            "description": "Requires: articles:create permission"
          },
          "response": []
        },
        {
          "name": "Update Article",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title_ar\": \"مقال محدث\",\n  \"title_en\": \"Updated Article\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/articles/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "articles", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "article_id_here"
                }
              ]
            },
            "description": "Requires: articles:update permission"
          },
          "response": []
        },
        {
          "name": "Delete Article",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/articles/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "articles", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "article_id_here"
                }
              ]
            },
            "description": "Requires: articles:delete permission"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin Management",
      "item": [
        {
          "name": "Create Admin with Books & Articles Permissions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{super_admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Books & Articles Admin\",\n  \"email\": \"books.admin@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\",\n  \"permissions\": [\n    {\n      \"books\": [\"view\", \"create\", \"update\", \"delete\"],\n      \"articles\": [\"view\", \"create\", \"update\", \"delete\"]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/register",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "register"]
            },
            "description": "Create admin with full books and articles permissions"
          },
          "response": []
        },
        {
          "name": "Update Admin Permissions",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{super_admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permissions\": [\n    {\n      \"books\": [\"view\", \"create\"],\n      \"articles\": [\"view\"]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "admin_id_here"
                }
              ]
            },
            "description": "Update admin permissions (limited access example)"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "your_admin_token_here",
      "type": "string"
    },
    {
      "key": "super_admin_token",
      "value": "your_super_admin_token_here",
      "type": "string"
    }
  ]
}
